# --- PostgreSQL ---
# Локальная разработка через docker-compose поднимает Postgres на localhost:5432.
# Параметры (имя БД, пользователь, пароль) задаются в docker-compose.yml.
DATABASE_URL="postgresql://ali:ali@localhost:5432/ali?schema=public"

# --- Auth.js (NextAuth v5) ---
# Сгенерируйте секрет: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="замените-на-свой-секрет"
AUTH_TRUST_HOST=true
