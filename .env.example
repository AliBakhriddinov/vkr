# --- PostgreSQL ---
# Локальная разработка через docker-compose поднимает Postgres на localhost:5432.
# Параметры (имя БД, пользователь, пароль) задаются в docker-compose.yml.
DATABASE_URL="postgresql://ali:ali@localhost:5432/ali?schema=public"

# --- Auth.js (NextAuth v5) ---
# Сгенерируйте секрет: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="замените-на-свой-секрет"
AUTH_TRUST_HOST=true

# --- Продакшн (Vercel + облачный PostgreSQL) ---
# На Vercel эти переменные задаются в Project Settings -> Environment Variables;
# файл .env в продакшн не используется.
#
# DATABASE_URL — строка подключения к облачной БД (Neon / Supabase):
#   * в приложении (рантайм на Vercel) используйте ПУЛ-соединение (pooled / pgbouncer);
#   * для миграций "prisma migrate deploy" нужно ПРЯМОЕ (direct) соединение.
# AUTH_SECRET — длинный случайный секрет (генерация — как выше).
# AUTH_TRUST_HOST=true — обязательно при работе за прокси (Vercel).
